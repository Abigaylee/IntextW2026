# Copy to .env in the repository root (two levels above src/Lighthouse.Web). Loaded in Development only.

# Supabase / PostgreSQL (Npgsql connection string)
ConnectionStrings__DefaultConnection=Host=YOUR_PROJECT.supabase.co;Port=5432;Database=postgres;Username=postgres;Password=YOUR_PASSWORD;SSL Mode=Require;Trust Server Certificate=true

# Optional: seed an initial Admin user (12+ char password per policy)
Seed__AdminEmail=admin@example.com
Seed__AdminPassword=ChangeMe123456!

# Supabase project (reference / client-side if needed)
SUPABASE_URL=https://YOUR_PROJECT.supabase.co
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE=

# ASP.NET
ASPNETCORE_ENVIRONMENT=Development
